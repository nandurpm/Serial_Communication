{
  "application": {
    "name": "Serial Communication Monitor",
    "version": "1.0.0",
    "language": "English"
  },
  "serial": {
    "default_baudrate": 9600,
    "default_parity": "N",
    "default_stopbits": 1,
    "default_timeout": 1.0
  },
  "modbus": {
    "slave_id": 1,
    "read_timeout": 1.0,
    "max_registers": 125
  },
  "ui": {
    "theme": "default",
    "font_size": 10,
    "window_width": 1200,
    "window_height": 700
  },
  "monitoring": {
    "auto_scan_interval": 1.0,
    "max_history_entries": 1000,
    "data_retention_days": 30
  },
  "logging": {
    "level": "INFO",
    "file": "app.log",
    "max_size_mb": 10
  }
}
